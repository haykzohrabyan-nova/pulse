# Cloudflare Pages — HTTP Headers
# ─────────────────────────────────
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# ── HTML pages: always revalidate ──────────────────────────
/*.html
  Cache-Control: no-cache, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

/
  Cache-Control: no-cache, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

# ── JS files: short-cache (unhashed filenames) ───────────────────
# All JS files in this deployment use plain (unhashed) filenames.
# Use a 5-min TTL so deploys are visible within minutes from CF edge.
# The HTML build script injects ?v=<git-sha> query strings to bust
# browser caches on deploy — but immutable would defeat staging
# verification via plain curl. Short TTL here is the safe default.
#
# NOTE: If content-hashed assets are ever added (e.g. app-<hash>.js),
# add an explicit long-cache rule ABOVE this wildcard for those patterns.
/*.js
  Cache-Control: public, max-age=300, must-revalidate

# ── Generated configs (no-store: must always reflect latest deploy) ──
/pulse-config.local.js
  Cache-Control: no-store

# ── Static assets: long-term cache ──────────────────────────
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=86400

# ── Security headers on all routes ──────────────────────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
