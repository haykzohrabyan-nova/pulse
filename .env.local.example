# ── Pulse Proxy — Local Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local.

# ── Claude / Anthropic (required for /manychat) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── HubSpot (required for lead CRM push from /manychat) ──────────────────────
HUBSPOT_TOKEN=pat-...

# HubSpot pipeline and deal stage internal IDs
# Find pipeline ID: GET https://api.hubapi.com/crm/v3/pipelines/deals
# Find stage IDs inside the pipeline response
HUBSPOT_PIPELINE_ID=default
HUBSPOT_STAGE_QUOTING=quoting
HUBSPOT_STAGE_SAMPLE=sample
HUBSPOT_STAGE_PENDING_DECISION=pendingdecision

# HubSpot owner IDs for Ernesto and Gary (find in HubSpot → Settings → Users)
AM_ERNESTO_HUBSPOT_OWNER_ID=
AM_GARY_HUBSPOT_OWNER_ID=

# ── Twilio (required for AM alert SMS from /manychat, and /proxy/twilio/sms) ──
PULSE_TWILIO_ACCOUNT_SID=AC...
PULSE_TWILIO_AUTH_TOKEN=...
# Sender — use either a phone number OR a Messaging Service SID (MG...)
PULSE_TWILIO_FROM=+1...
# PULSE_TWILIO_MESSAGING_SERVICE_SID=MG...

# AM mobile phone numbers for handoff text alerts
AM_ERNESTO_PHONE=+1...
AM_GARY_PHONE=+1...

# Optional: force all SMS to this number instead of real target (for testing)
# PULSE_TWILIO_TEST_TO=+1...

# ── Notes ─────────────────────────────────────────────────────────────────────
# ManyChat External Request URL:
#   POST https://instagram.pixelpressprint.com/manychat
#   Body: { "message": "...", "first_name": "...", "last_name": "...",
#           "subscriber_id": "...", "brand": "bazaar" | "pixelpress" }
#
# Utility endpoints (local only):
#   GET  http://localhost:8879/manychat/gaps         — knowledge gap log
#   GET  http://localhost:8879/manychat/sessions     — active sessions
#   DELETE http://localhost:8879/manychat/session/ID — reset session
